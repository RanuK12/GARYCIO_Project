# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/garycio
DB_HOST=localhost
DB_PORT=5432
DB_NAME=garycio
DB_USER=user
DB_PASSWORD=password

# WhatsApp API — proveedor
# "meta"      → Cloud API directo: WHATSAPP_TOKEN = Bearer token de Meta
# "360dialog" → WHATSAPP_TOKEN = D360-API-KEY del Hub de 360dialog (recomendado)
WHATSAPP_PROVIDER=360dialog

# Con 360dialog: copiar el D360-API-KEY del Hub
# Con Meta directo: copiar el token permanente de Meta Developers
WHATSAPP_TOKEN=EAAxxxxxxx_o_D360_API_KEY

WHATSAPP_PHONE_NUMBER_ID=123456789   # ID del número (solo necesario con WHATSAPP_PROVIDER=meta)
WHATSAPP_VERIFY_TOKEN=mi_token_secreto  # Token para verificar el webhook (cualquier string)
WHATSAPP_BUSINESS_ACCOUNT_ID=        # (opcional) ID de cuenta de WhatsApp Business
WHATSAPP_API_VERSION=v22.0           # Versión de la Graph API (solo para meta)
# App Secret de Meta — habilita verificación X-Hub-Signature-256 en webhook.
# CON 360dialog: dejar vacío (la firma de Meta no aplica en su pipeline).
# CON Meta directo: setear con el App Secret real (App Dashboard → Basic).
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_PHONE=5491XXXXXXXXXX  # Tu número de WhatsApp Business sin + (ej: 5491171560000)

# App
CEO_PHONE=5491XXXXXXXXXX           # Número del CEO sin + (ej: 5491134567890)
PORT=3000
NODE_ENV=production                 # development | production

# Seguridad: API key para endpoints /admin/* (mínimo 16 caracteres)
# Generá uno con: openssl rand -hex 32
ADMIN_API_KEY=cambiar_por_clave_segura_minimo_16_chars

# Galpón / Punto de partida de los camiones
GALPON_DIRECCION=Murature 3820, Villa Lynch, Provincia de Buenos Aires
GALPON_LAT=-34.5944
GALPON_LON=-58.5339

# Ituran SOAP (tracking GPS real-time - necesita permiso CanUseWebserviceApi)
ITURAN_USER=              # Usuario del Web Service SOAP
ITURAN_PASSWORD=          # Contraseña del Web Service SOAP

# Ituran REST API (viajes/trips)
ITURAN_API_USER=          # Usuario REST API
ITURAN_API_PASSWORD=      # Contraseña REST API
ITURAN_API_URL=https://web2.ituran.com.ar/ibi2_services/tripsData.svc/GetTripsByDateDriverNVehicleNTripID

# Admin phones para alertas CEO (comma-separated, sin +)
ADMIN_PHONES=5491XXXXXXXXXX,393XXXXXXXXXX,5491XXXXXXXXXX,5491XXXXXXXXXX  # comma-separated sin +

# Límite de velocidad para alertas (km/h)
SPEED_LIMIT_KMH=80

# Logging
LOG_LEVEL=info

# Rate limiting
SEND_RATE_PER_SECOND=30   # Mensajes por segundo (máx WhatsApp: 80)
MAX_RETRIES=3              # Reintentos con backoff exponencial

# Test mode: restringe envíos SOLO a números en whitelist
TEST_MODE=false
TEST_PHONES=                          # comma-separated, ej: 393445721753,5491126330388

# Capacidad controlada (LIMITE_DONANTES_BOT) — sistema first-come-first-served.
# Se administra vía DB (tabla configuracion_sistema) y el endpoint:
#   POST /admin/capacidad/limite { limite: 10 }
# Para re-launch progresivo post-incidente 2026-04, arrancar en 10.

# Difusión masiva: categoría de mensaje Meta
# false = texto libre (Meta cobra como "marketing" ~$0.058/conv)
# true  = template aprobado (Meta cobra como "utility" ~$0.014/conv, 4x más barato)
# Para activar: crear template "recoleccion_aviso" en 360dialog Hub con categoría UTILITY
DIFUSION_USE_TEMPLATE=false
# Template mañana: 3 vars {{1}}=nombre {{2}}=días {{3}}=horario (para horario < 12:00)
DIFUSION_TEMPLATE_NAME=recoleccion_aviso1
# Template tarde: 2 vars {{1}}=nombre {{2}}=días (para horario >= 12:00 o sin horario)
DIFUSION_TEMPLATE_NAME_TARDE=recoleccion_aviso_tarde

# Geocoding (Nominatim gratuito - 1 request/seg)
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_COUNTRY=ar
GEOCODING_RATE_MS=1100     # ms entre requests (Nominatim exige ≥1 seg)
